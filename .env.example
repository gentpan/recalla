# Recalla 配置

# 服务器
RECALLA_ADDR=:14200
RECALLA_API_KEY=your-secret-api-key

# PostgreSQL
RECALLA_DB_URL=postgres://recalla:recalla2025@localhost:5432/recalla?sslmode=disable

# Qdrant
RECALLA_QDRANT_URL=http://localhost:6333
RECALLA_QDRANT_COLLECTION=memories

# Embedding API (OpenAI 兼容格式)
RECALLA_EMBEDDING_URL=https://api.openai.com/v1/embeddings
RECALLA_EMBEDDING_KEY=your-openai-key
RECALLA_EMBEDDING_MODEL=text-embedding-3-small
RECALLA_EMBEDDING_DIM=1536

# AI 压缩 (OpenAI 兼容格式)
RECALLA_LLM_URL=https://api.openai.com/v1/chat/completions
RECALLA_LLM_KEY=your-openai-key
RECALLA_LLM_MODEL=gpt-4o-mini
